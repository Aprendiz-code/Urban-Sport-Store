# Example environment variables for the project (root)
# Copy to .env.local and fill values before running or deploying

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Client keys (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_STORAGE_BUCKET=products

# Runtime
NODE_ENV=development

# Do NOT store the service role key in client-side files or commit it.

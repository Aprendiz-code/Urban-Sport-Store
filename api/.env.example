# Example environment variables for the backend
# Copy to .env.local (api/.env.local) and fill values before running or deploying

DATABASE_URL=postgresql://user:password@db-host:5432/dbname
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sbx_xxx
CORS_ORIGINS=https://www.urbansportstore.online,http://localhost:4173
E2E_SECRET=change_me
NODE_ENV=production
PORT=4000
NODE_ENV=development

# Database: PostgreSQL for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urbansportstore

# JWT Configuration
JWT_SECRET=replace-me-with-strong-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7

# Cookie & Security
COOKIE_SAMESITE=lax
SECURE_COOKIES=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase Integration (admin backend access)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<get-from-supabase-dashboard>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# Initial Admin User (seeded to database)
SEED_ADMIN_EMAIL=admin@urbansportstore.dev
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin Urban Sport Store

# E2E Testing
E2E_SECRET=test-secret
